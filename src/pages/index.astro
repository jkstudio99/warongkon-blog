---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { projects } from './projects/projects';
import ProjectList from '../components/ProjectList.astro'
import PostItem from '../components/PostItem.astro';
import { Image } from 'astro:assets';
import AvaImage from '../assets/img/ava.jpg';

type BlogPost = CollectionEntry<'blog'>;

const top6Projects = projects.slice(0, 6);
const posts = (await getCollection('blog'))
  .sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container'>
		<div class='mb-20 w-full'>
      <div class='flex flex-col-reverse items-start gap-10 md:flex-row md:items-center md:gap-16'>
        <div class="flex-1">
          <h1 class="mb-8 text-4xl font-semibold leading-tight tracking-tighter sm:text-5xl">
            Warongkon Blog
          </h1>

          <div class="space-y-4">
            <p class="text-lg leading-relaxed text-zinc-700 dark:text-zinc-300 sm:text-xl">
              Hi, I’m <strong>Warongkon</strong> – an enthusiastic Software Developer with 4 years of experience, specializing in <strong>C#, TypeScript, Angular, ASP.NET Core, SQL Server, and MongoDB</strong>. 
            </p>
            <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-xl">
              I’m passionate about leveraging my love for C# to build high-performance, scalable solutions and RESTful APIs, following <strong>Clean Code</strong> and <strong>SOLID</strong> principles to drive efficient development workflows and impactful software solutions.
            </p>
          </div>
        </div>
        <div class="group relative shrink-0">
          <!-- Soft Background Glow for Depth -->
          <div class="absolute -inset-6 rounded-full bg-zinc-100 blur-3xl transition-all duration-700 group-hover:bg-zinc-200 dark:bg-zinc-800/40"></div>
          
          <!-- Sleek Minimal Premium Frame -->
          <div class="relative z-10 overflow-hidden rounded-[2rem] border border-zinc-200 bg-white p-1 shadow-[0_12px_24px_-8px_rgba(0,0,0,0.12)] dark:border-zinc-700 dark:bg-zinc-800">
            <Image 
              src={AvaImage} 
              alt="Warongkon" 
              class="h-40 w-40 rounded-[1.7rem] object-cover transition-transform duration-700 group-hover:scale-105 sm:h-56 sm:w-56"
            />
          </div>
        </div>
      </div>
		<div class='mt-6 mb-12'>
		  <div class="mb-2 flex justify-between gap-3 border-b dark:border-b-zinc-700">
		    <h2 class="mb-4 text-2xl font-semibold">Recent Posts</h2>
		    <a href="/posts/" class="inline-block py-2 text-[1.08rem] font-semibold underline dark:prose-invert">All posts &raquo;</a>
		  </div>
		  <div>
		    {
		      posts.map((post: BlogPost) => (
		        <PostItem post={post} />
		      ))
		    }      
		  </div>
		</div>
		<div>
		  <div class="mb-2 flex justify-between gap-3">
		    <h2 class="mb-4 text-2xl font-semibold">My Projects</h2>
		    <a href="/projects/" class="inline-block py-2 text-[1.08rem] font-semibold underline dark:prose-invert">All projects &raquo;</a>
		  </div>
		  <ProjectList projects={top6Projects}/>
		</div>

		</main>
	</div>
</BaseLayout>
