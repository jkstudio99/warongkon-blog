---
import BaseLayout from '../layouts/BaseLayout.astro';
import Prose from '../components/Prose.astro';
import { Image } from 'astro:assets';
import AvaImage from '../assets/img/ava.jpg';

---

<BaseLayout
	title="About Me"
	description="About Warongkon - Software Developer with 4 years of experience"
>
  <div class='container'>
		<main>
      <article>
        <!-- Hero Section -->
        <div class='mb-16 w-full'>
          <h1 class="mb-6 text-4xl font-semibold tracking-tighter sm:text-5xl">
            About Me
          </h1>
          <p class="max-w-4xl text-xl leading-relaxed text-zinc-700 dark:text-zinc-300 sm:text-2xl">
            Hi, I’m <strong>Warongkon</strong> – a passionate Software Developer dedicated to building efficient, scalable, and high-performance solutions.
          </p>
        </div>

        <Prose>
          <div class="grid gap-12 md:grid-cols-2">
            <div>
              <h2 class="!mt-0">Professional Journey</h2>
              <p>
                My journey into professional software development began in 2022. Over the past <strong>4 years</strong>, I have honed my skills by developing enterprise-grade web applications.
              </p>
              <p>
                I am a problem-solver who enjoys tackling complex challenges with clean and effective code. While my expertise lies heavily within the <strong>Microsoft ecosystem</strong>, I maintain the flexibility to adapt and employ the best tools for any given task.
              </p>
            </div>
            
            <div>
              <h2 class="!mt-0">Skills & Expertise</h2>
              <ul class="space-y-2 !pl-0 list-none">
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-900 dark:bg-zinc-100"></span>
                  <span><strong>Backend:</strong> C#, ASP.NET Core, RESTful APIs, Unit Testing</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-900 dark:bg-zinc-100"></span>
                  <span><strong>Frontend:</strong> Angular, TypeScript, Tailwind CSS, Responsive UI</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-900 dark:bg-zinc-100"></span>
                  <span><strong>Data:</strong> SQL Server, MongoDB, Database Optimization</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-900 dark:bg-zinc-100"></span>
                  <span><strong>Architecture:</strong> SOLID, Clean Code, Design Patterns, Microservices</span>
                </li>
              </ul>
            </div>
          </div>

          <hr class="my-16 border-zinc-200 dark:border-zinc-800" />

          <div class="w-full">
            <h2>Vision for 2026</h2>
            <p>
              This year, I am focused on deepening my expertise in <strong>System Design</strong> and integrating <strong>AI-driven tools</strong> to enhance the development lifecycle. I believe that modern software requires a blend of robust architecture and intelligent automation.
            </p>
            <p>
              I firmly believe that "learning is a lifelong journey." This blog serves as a digital journal where I document my findings and share knowledge with the community. Thank you for stopping by and getting to know me!
            </p>
          </div>
        </Prose>
      </article>
    </main>
  </div>
</BaseLayout>
