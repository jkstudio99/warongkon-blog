---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath?: string;
}

const { currentPage, totalPages, basePath = '/posts' } = Astro.props;

const getPageHref = (page: number) => page === 1 ? `${basePath}/` : `${basePath}/${page}/`;
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
---

{totalPages > 1 && (
  <nav class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between" aria-label="Posts pagination">
    <div class="text-[1.05rem] font-semibold text-zinc-600 dark:text-zinc-300">
      Page {currentPage} of {totalPages}
    </div>
    <div class="flex flex-wrap gap-2">
      {currentPage > 1 ? (
        <a
          class="min-h-11 rounded-lg border border-zinc-300 px-4 py-2 text-[1.05rem] font-bold text-zinc-700 no-underline transition-colors duration-200 hover:border-zinc-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-300"
          href={getPageHref(currentPage - 1)}
        >
          Previous
        </a>
      ) : (
        <span class="min-h-11 rounded-lg border border-zinc-200 px-4 py-2 text-[1.05rem] font-bold text-zinc-400 dark:border-zinc-800 dark:text-zinc-600">
          Previous
        </span>
      )}
      {pageNumbers.map((page) => page === currentPage ? (
        <span
          class="min-h-11 rounded-lg border border-zinc-800 bg-zinc-900 px-4 py-2 text-[1.05rem] font-bold text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900"
          aria-current="page"
        >
          {page}
        </span>
      ) : (
        <a
          class="min-h-11 rounded-lg border border-zinc-300 px-4 py-2 text-[1.05rem] font-bold text-zinc-700 no-underline transition-colors duration-200 hover:border-zinc-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-300"
          href={getPageHref(page)}
        >
          {page}
        </a>
      ))}
      {currentPage < totalPages ? (
        <a
          class="min-h-11 rounded-lg border border-zinc-300 px-4 py-2 text-[1.05rem] font-bold text-zinc-700 no-underline transition-colors duration-200 hover:border-zinc-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-300"
          href={getPageHref(currentPage + 1)}
        >
          Next
        </a>
      ) : (
        <span class="min-h-11 rounded-lg border border-zinc-200 px-4 py-2 text-[1.05rem] font-bold text-zinc-400 dark:border-zinc-800 dark:text-zinc-600">
          Next
        </span>
      )}
    </div>
  </nav>
)}
