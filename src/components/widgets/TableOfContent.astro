---
const { headings, maxLevel = 3 } = Astro.props;
const toc = buildToc(headings);
function buildToc(headings: any) {
	const _toc: any = [];
	const parentHeadings = new Map();
	(headings || []).forEach((h: any) => {
		const heading = { ...h, subheadings: [] };
		parentHeadings.set(heading.depth, heading);
		// Change 2 to 1 if your markdown includes your <h1>
		if (heading.depth === 2) {
			_toc.push(heading);
		} else {
			if (maxLevel > 2) {
				parentHeadings.get(heading.depth - 1)?.subheadings?.push(heading);
			}
		}
	});
	return _toc;
}
---

<nav class='toc sticky top-5 py-3 lg:-ml-3' aria-label='Table of contents'>
	<h3 class='mb-3 px-3 text-[1.02rem] font-extrabold uppercase tracking-wide'>On This Page</h3>
	<ul class='toc-list max-h-[calc(100vh-90px)] overflow-auto text-[1.04rem] leading-7 text-[var(--color-content-secondary)]'>
		{
			toc.map((heading: any) => (
				<li>
					<a
						class='block border-l-2 border-transparent px-3 py-2 font-bold leading-7 text-inherit text-zinc-700 transition-colors duration-200 hover:border-zinc-700 hover:text-zinc-950 dark:text-zinc-300 dark:hover:border-zinc-200 dark:hover:text-zinc-50'
						href={'#' + heading.slug}>
						{heading.text}
					</a>
					{heading.subheadings?.length > 0 && (
						<ul>
							{heading.subheadings.map((subheading: any) => (
								<li>
									<a
										class='block border-l-2 border-transparent py-2 pl-6 pr-3 leading-7 text-inherit text-zinc-700 transition-colors duration-200 hover:border-zinc-500 hover:text-zinc-950 dark:text-zinc-300 dark:hover:border-zinc-300 dark:hover:text-zinc-50'
										href={'#' + subheading.slug}>
										{subheading.text}
									</a>
								</li>
							))}
						</ul>
					)}
				</li>
			))
		}
	</ul>
</nav>
<style>
	.toc-list::-webkit-scrollbar {
		width: 5px;
	}

	/* Track */
	.toc-list::-webkit-scrollbar-track {
		background: transparent;
	}

	/* Handle */
	.toc-list::-webkit-scrollbar-thumb {
		background: #eeeeee;
		border-radius: 5px;
	}
  :global(.dark) .toc-list::-webkit-scrollbar-thumb {
		background: #2e2e2e;
		border-radius: 5px;
	}
</style>
